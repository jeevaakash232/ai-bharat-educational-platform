# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# AWS Configuration (REQUIRED - BACKEND ONLY - NEVER EXPOSE TO FRONTEND)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# Bedrock Configuration (us-east-1 for Bedrock models)
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# S3 Configuration (for file storage)
S3_REGION=us-east-1
S3_BUCKET_NAME=your_s3_bucket_name_here

# DynamoDB Configuration
DYNAMODB_TABLE_USER_HISTORY=UserHistory
DYNAMODB_TABLE_FOCUS=FocusTracking
DYNAMODB_TABLE_HEALTH=HealthLogs

# Server Configuration
PORT=3001
NODE_ENV=production

# Frontend URL (REQUIRED for CORS in production)
# For local development: http://localhost:5173
# For production: https://your-app.vercel.app (or your deployed frontend URL)
FRONTEND_URL=http://localhost:5173
