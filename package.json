{
  "name": "edulearn-desktop",
  "version": "1.0.0",
  "description": "AI-Powered Educational Platform for Classes 1-12 with comprehensive subject coverage",
  "main": "electron.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "deploy:vercel": "vercel --prod",
    "deploy:netlify": "npm run build && netlify deploy --prod --dir=dist",
    "deploy:auto": "npm run build && netlify deploy --prod --dir=dist",
    "start": "node server.cjs",
    "server": "node server.cjs",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "electron": "electron .",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:build": "electron-builder",
    "electron:build:mac": "electron-builder --mac",
    "electron:build:win": "electron-builder --win",
    "electron:build:linux": "electron-builder --linux",
    "mobile:build": "npm run build && npx cap copy && npx cap sync",
    "mobile:android": "npm run mobile:build && npx cap open android",
    "mobile:ios": "npm run mobile:build && npx cap open ios",
    "mobile:run:android": "npm run mobile:build && npx cap run android",
    "mobile:run:ios": "npm run mobile:build && npx cap run ios"
  },
  "build": {
    "appId": "com.edulearn.app",
    "productName": "EduLearn",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron.cjs",
      "server.cjs",
      "src/**/*",
      "public/**/*",
      "index.html",
      "package.json",
      "books-database.json",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.education",
      "icon": "public/vite.svg",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "public/vite.svg",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "public/vite.svg",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Education"
    }
  },
  "keywords": [
    "education",
    "ai",
    "react",
    "vite",
    "groq",
    "learning-platform",
    "tutoring",
    "educational-technology",
    "student-portal",
    "curriculum"
  ],
  "author": "Jeeva Akash",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jeevaakash232/educational-platform.git"
  },
  "homepage": "https://jeevaakash232.github.io/educational-platform",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@capacitor/android": "^8.0.2",
    "@capacitor/cli": "^8.0.2",
    "@capacitor/core": "^8.0.2",
    "@capacitor/ios": "^8.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.4",
    "express": "^4.18.2",
    "file-saver": "^2.0.5",
    "groq-sdk": "^0.3.0",
    "html2pdf.js": "^0.14.0",
    "lucide-react": "^0.263.1",
    "multer": "^1.4.5-lts.1",
    "quill": "^2.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-quill": "^2.0.0",
    "react-router-dom": "^6.8.0",
    "uuid": "^9.0.1",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^7.6.0",
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0",
    "gh-pages": "^6.1.0",
    "vite": "^4.2.0",
    "wait-on": "^9.0.3"
  }
}
