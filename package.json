{
  "name": "edulearn-web",
  "version": "1.0.0",
  "description": "AI-Powered Educational Platform for Classes 1-12 with comprehensive subject coverage",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "deploy:vercel": "vercel --prod",
    "deploy:netlify": "npm run build && netlify deploy --prod --dir=dist",
    "deploy:auto": "npm run build && netlify deploy --prod --dir=dist",
    "backend": "cd backend && npm start",
    "dev:full": "concurrently \"npm run backend\" \"npm run dev\""
  },
  "keywords": [
    "education",
    "ai",
    "react",
    "vite",
    "aws-bedrock",
    "learning-platform",
    "tutoring",
    "educational-technology",
    "student-portal",
    "curriculum"
  ],
  "author": "Jeeva Akash",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jeevaakash232/educational-platform.git"
  },
  "homepage": "https://jeevaakash232.github.io/educational-platform",
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.999.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "axios": "^1.13.6",
    "cors": "^2.8.5",
    "dotenv": "^17.2.4",
    "express": "^4.18.2",
    "file-saver": "^2.0.5",
    "firebase": "^12.10.0",
    "html2pdf.js": "^0.14.0",
    "localforage": "^1.10.0",
    "lucide-react": "^0.263.1",
    "meyda": "^5.6.3",
    "multer": "^1.4.5-lts.1",
    "quill": "^2.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-quill": "^2.0.0",
    "react-router-dom": "^6.8.0",
    "uuid": "^9.0.1",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^7.6.0",
    "gh-pages": "^6.1.0",
    "tailwindcss": "^3.4.19",
    "vite": "^4.2.0"
  }
