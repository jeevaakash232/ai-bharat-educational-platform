# Frontend Environment Variables
# Copy this file to .env and fill in your actual values

# Backend API URL (REQUIRED for production deployment)
# For local development: http://localhost:3001
# For production: https://your-backend.onrender.com (or your deployed backend URL)
VITE_API_URL=http://localhost:3001

# Firebase Configuration (REQUIRED)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# AWS Configuration (OPTIONAL - only if using AWS services directly from frontend)
# Note: It's recommended to use backend API instead of direct AWS access from frontend
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_aws_access_key_here
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
# AWS_S3_BUCKET_NAME=your_s3_bucket_name_here
# BEDROCK_MODEL_ID=google.gemma-3-12b-it
