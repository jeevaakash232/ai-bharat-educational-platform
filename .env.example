# ========================================
# 🎤 VOICE AI CHATBOT CONFIGURATION
# ========================================

# Groq API Configuration (REQUIRED for AI chatbot)
# Get your FREE API key from: https://console.groq.com/keys
VITE_GROQ_API_KEY=your_groq_api_key_here

# ========================================
# 📚 AWS S3 Configuration (Optional)
# ========================================
# Only needed if using cloud storage for books
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=edulearn-books-storage

# ========================================
# 🎥 AWS S3 Video Configuration (Optional)
# ========================================
# For video recording uploads and streaming
REACT_APP_AWS_ACCESS_KEY_ID=your_aws_access_key_id
REACT_APP_AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
REACT_APP_AWS_REGION=ap-south-1
REACT_APP_S3_BUCKET_NAME=edulearn-videos

# ========================================
# 📖 SETUP INSTRUCTIONS
# ========================================
# 1. Copy this file to .env
# 2. Get FREE Groq API key: https://console.groq.com/keys
# 3. Replace VITE_GROQ_API_KEY with your actual key
# 4. (Optional) Add AWS credentials if using cloud storage
# 5. Restart your dev server: npm run dev

# ========================================
# ✨ VOICE AI FEATURES (100% FREE)
# ========================================
# ✅ Voice Input (Speech-to-Text) - Browser built-in
# ✅ Voice Output (Text-to-Speech) - Browser built-in
# ✅ AI Processing - Groq (FREE tier)
# ✅ 10+ Languages - Tamil, Hindi, Telugu, etc.
# ✅ Dual Language Responses - Native + English

# Example Groq API key format (do not use this):
# VITE_GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========================================
# 🚀 READY TO USE
# ========================================
# Once configured, import and use:
# import VoiceEnabledChatbot from './components/VoiceEnabledChatbot'
# 
# See VOICE_AI_SETUP.md for complete guide
